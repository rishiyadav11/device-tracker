# NeonDB Postgres connection string (pooled connection recommended)
# Get this from https://console.neon.tech -> your project -> Connection Details
DATABASE_URL="postgresql://user:password@ep-example-12345.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Auth.js secret - generate with: npx auth secret
AUTH_SECRET="replace-with-generated-secret"

# Base URL of the app (used by Auth.js). In production set to your Vercel URL.
NEXTAUTH_URL="http://localhost:3000"
