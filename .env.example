# NeonDB Postgres connection string (pooled connection recommended)
# Get this from https://console.neon.tech -> your project -> Connection Details
DATABASE_URL="postgresql://user:password@ep-example-12test@345.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Auth.js secret (REQUIRED in production) - generate with: npx auth secret
# Login will fail on a deployed site if this is missing or differs between builds.
AUTH_SECRET="replace-with-generated-secret"

# Optional. Auth.js v5 auto-detects the host (trustHost is enabled in code),
# so you normally don't need this. If you set it, use AUTH_URL, e.g.
# AUTH_URL="https://your-app.vercel.app"
